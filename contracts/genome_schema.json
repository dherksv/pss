  "signal_type":    "string — adverse_drug_reaction | distress | misinformation | treatment_dissatisfaction | general",
  "sentiment_score":"float -1.0 to 1.0",
  "distress_level": "float 0.0 to 1.0",
  "confidence_score":"float 0.0 to 1.0",
  "entities": {
    "drugs":        "string[]",
    "symptoms":     "string[]",
    "conditions":   "string[]",
    "locations":    "string[]",
    "institutions": "string[]"
  },
  "geo": {
    "extracted_locations":  "string[]",
    "subreddit_geo_proxy":  "string — ISO country/region code",
    "google_trends_region": "string",
    "confidence":           "float"
  },
  "novelty": {
    "in_fda_label":     "boolean",
    "faers_count":      "integer",
    "internal_7d_count":"integer",
    "score":            "float 0.0 to 1.0"
  },
  "pii_detected":    "boolean",
  "phi_detected":    "boolean",
  "pii_redacted_text":"string | null",
  "explanation":     "string — human readable XAI explanation",
  "cluster_id":      "string (uuid) | null",
  "related_genome_ids":"string[]"
}
