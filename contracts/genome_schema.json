{
  "_comment": "Signal Genome v1.0 — DO NOT change without all 3 engineers agreeing",
  "genome_id":      "string (uuid)",
  "post_id":        "string (uuid)",
  "created_at":     "ISO8601 string",
  "source":         "string — eg: reddit/r/diabetes",
  "source_type":    "string — reddit | twitter | forum | rss",
  "source_url":     "string",
